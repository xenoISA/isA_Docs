{
  "name": "isa-docs",
  "version": "1.0.0",
  "description": "isA Platform Documentation",
  "scripts": {
    "dev": "next dev --webpack --port 4300",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app components lib --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint app components lib --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "isA",
    "documentation",
    "ai",
    "agents"
  ],
  "author": "isA Team",
  "license": "MIT",
  "dependencies": {
    "@xenoisa/core": "workspace:*",
    "@xenoisa/ui-web": "workspace:*",
    "@opentelemetry/auto-instrumentations-web": "^0.59.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.18",
    "ioredis": "^5.10.1",
    "next": "^16.1.5",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "zod": "^3.22.0",
    "@faker-js/faker": "^8.0.0",
    "@types/node": "20.19.30",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.10",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "pnpm": {
    "overrides": {
      "nextra>zod": "4.1.12",
      "nextra-theme-docs>zod": "4.1.12"
    }
  }
}
