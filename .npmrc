# Hoist SDK build/runtime deps to the root so Next can trace them, BUT keep
# `zod` nested per-package: @xenoisa/core needs zod v3 (126x z.record, a v4
# breaking change) while nextra v4 needs zod v4 (prettifyError). Flattening
# zod makes one shadow the other (#430/#349). Excluding it lets each resolve
# its own nested version.
public-hoist-pattern[]=*
public-hoist-pattern[]=!zod
